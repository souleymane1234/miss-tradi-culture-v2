# API Missplayce (actualités, émissions, votes)
VITE_API_BASE_URL=https://missplayce-dev.up.railway.app
VITE_API_TIMEOUT_MS=30000
VITE_API_ACCEPT_LANGUAGE=fr-FR,fr;q=0.9,*;q=0.8

# ID d'émission (optionnel : sinon dernière émission publique « Miss Tradi » avec éditions)
VITE_EMISSION_ID=

# true = données mock locales (src/data/editions.ts) sans appeler l'API
VITE_USE_MOCK_DATA=false

# Optionnel — jeton JWT pour candidature / video (sinon connexion dans le formulaire)
# VITE_API_ACCESS_TOKEN=

# Optionnel
# VITE_API_KEY=
